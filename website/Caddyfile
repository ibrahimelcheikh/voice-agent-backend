# AtlasPrimeX marketing website — static server for Railway.
# Railway injects $PORT; Caddy binds to it and serves the static files in /srv.
:{$PORT:8080} {
	root * /srv
	encode gzip zstd

	# Long cache for fingerprintable static assets (logo, favicons).
	@assets path /assets/* *.css *.js *.png *.ico *.svg
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# HTML should always be revalidated so deploys go live immediately.
	@html path *.html /
	header @html Cache-Control "public, max-age=0, must-revalidate"

	# Basic security headers.
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Serve index.html for unknown paths (keeps deep links working).
	try_files {path} {path}/ /index.html
	file_server
}
